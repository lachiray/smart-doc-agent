# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Provider selection ────────────────────────────────────────────────────────
# "anthropic"  → direct Anthropic API (needs ANTHROPIC_API_KEY below)
# "bedrock"    → AWS Bedrock        (needs AWS credentials below)
LLM_PROVIDER=anthropic

# ── Optional: override the model ID ──────────────────────────────────────────
# Defaults: anthropic → claude-sonnet-4-6
#           bedrock   → us.anthropic.claude-3-5-sonnet-20241022-v2:0
# MODEL_ID=

# ── Anthropic API (used when LLM_PROVIDER=anthropic) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── AWS Bedrock (used when LLM_PROVIDER=bedrock) ─────────────────────────────
# Leave blank if you're using an IAM role / instance profile instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# AWS_SESSION_TOKEN=   # only needed for temporary credentials
